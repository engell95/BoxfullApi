// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────
enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Order {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con usuario (comercio)
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  // Destinatario
  recipientName    String
  recipientEmail   String
  recipientPhone   String
  recipientAddress String
  recipientCity    String
  recipientDepartment String

  // Detalles de la orden
  deliveryDate DateTime
  instructions String?

  // Paquetes (embedded documents)
  packages Package[]

  // COD (Cash On Delivery)
  isCOD          Boolean @default(false)
  expectedAmount Float?  // Monto esperado al crear la orden
  collectedAmount Float? // Monto real recolectado (via webhook)

  // Estado
  status OrderStatus @default(PENDING)

  // Costo de envío aplicado al momento de creación
  shippingCost Float @default(0)
}

// ─────────────────────────────────────────────
// PACKAGE (embedded en Order)
// ─────────────────────────────────────────────
type Package {
  content  String
  quantity Int
  weight   Float
  width    Float
  height   Float
  length   Float
}

// ─────────────────────────────────────────────
// SHIPPING COST (configurable por día)
// ─────────────────────────────────────────────
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model ShippingCost {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek DayOfWeek @unique
  cost      Float
  updatedAt DateTime  @updatedAt
}
