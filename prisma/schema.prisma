// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
enum Role {
  ADMIN
  COMPANY_OWNER
  COMPANY_USER
}

model User {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  gender      String?
  dateOfBirth DateTime?
  whatsapp    String?
  email       String    @unique
  password    String
  role      Role     @default(COMPANY_USER)
  
  companyId String?  @db.ObjectId
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ─────────────────────────────────────────────
// COMPANY (Comercio)
// ─────────────────────────────────────────────
model Company {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  nit         String?
  phone       String?
  address     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  orders      Order[]
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────
enum OrderStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Order {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con usuario que la creó
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  // Relación con la empresa dueña de la orden
  companyId String @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id])

  // Dirección de recolección
  pickupAddress    String

  // Destinatario
  recipientFirstName    String
  recipientLastName     String
  recipientEmail   String
  recipientPhone   String
  recipientAddress String
  recipientMunicipality String
  recipientDepartment String
  referencePoint   String?

  // Detalles de la orden
  deliveryDate DateTime
  instructions String?

  // Paquetes (embedded documents)
  packages Package[]

  // COD (Cash On Delivery)
  isCOD          Boolean @default(false)
  expectedAmount Float?  // Monto esperado al crear la orden
  collectedAmount Float? // Monto real recolectado (via webhook)

  // Estado
  status OrderStatus @default(PENDING)

  // Costo de envío aplicado al momento de creación
  shippingCost Float @default(0)
}

// ─────────────────────────────────────────────
// PACKAGE (embedded en Order)
// ─────────────────────────────────────────────
type Package {
  content      String
  weightInLbs  Float
  width        Float
  height       Float
  length       Float
}

// ─────────────────────────────────────────────
// SHIPPING COST (configurable por día)
// ─────────────────────────────────────────────
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model ShippingCost {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek DayOfWeek @unique
  cost      Float
  updatedAt DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// PARAMETER (Configuraciones dinámicas)
// ─────────────────────────────────────────────
enum ParameterDataType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model Parameter {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  key         String            @unique
  value       String            // Se guarda como string y se parsea en código
  dataType    ParameterDataType @default(STRING)
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// UBICACIONES (Departamentos y Municipios)
// ─────────────────────────────────────────────
model Department {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String         @unique
  municipalities Municipality[]
}

model Municipality {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  departmentId String     @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id])
}
